# =============================================================================
# NetworkMemories — Demon's Souls Server (desse-docker)
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# NETWORK
# -----------------------------------------------------------------------------
# Public IP of your server (reachable by PS3 clients / RPCS3)
SERVER_IP=YOUR_SERVER_IP

# -----------------------------------------------------------------------------
# SERVER PORTS
# Port the Demon's Souls emulator listens on
# -----------------------------------------------------------------------------
DESSE_PORT=18000
DESSE_BIND=0.0.0.0

# -----------------------------------------------------------------------------
# DNS — resolves Demon's Souls hostnames → SERVER_IP
# Domains captured:
#   *.sonyentertainmentnetwork.com
#   *.demonsouls.com
#   *.fromsoftware.jp (specific endpoints)
# -----------------------------------------------------------------------------
DNS_PORT=53

# -----------------------------------------------------------------------------
# REGIONS
# Controls which regions are active on this server.
# Players only see summon signs from their own region.
# Available: EU, US, JP  (comma-separated)
# -----------------------------------------------------------------------------
ACTIVE_REGIONS=EU,US,JP

# -----------------------------------------------------------------------------
# DATA PATHS (inside container — do not change unless you know what you're doing)
# -----------------------------------------------------------------------------
DATA_DIR=/app/data
DB_DIR=/app/db

# -----------------------------------------------------------------------------
# ADMIN PANEL (Flask — Python)
# -----------------------------------------------------------------------------
ADMIN_HOST=0.0.0.0
ADMIN_PORT=8080
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
ADMIN_SECRET_KEY=CHANGE_ME_FLASK_SECRET_KEY

# -----------------------------------------------------------------------------
# LOGGING
# DEBUG | INFO | WARNING | ERROR
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
